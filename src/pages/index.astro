---
import Layout from '../layouts/Layout.astro';
---
<Layout title="International Meeting Time Zone Coordinator" description="Find best meeting time for distributed teams. Visual timeline shows overlapping work hours.">
  <style>.tz-bar{height:32px;border-radius:4px;}.tz-work{background:linear-gradient(90deg,#06b6d4,#0891b2);}.tz-sleep{background:#e5e7eb;}.tz-overlap{background:linear-gradient(90deg,#10b981,#059669);}</style>
  <section class="mb-8"><p class="text-gray-600 leading-relaxed" data-i18n="pageDesc">Find <strong>best meeting time</strong> for teams across <strong>multiple time zones</strong>. Select cities and see overlap hours in green.</p></section>
  <section id="calculator">
    <div class="grid sm:grid-cols-3 gap-4 mb-6">
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="tz1" class="block text-sm font-semibold text-gray-700 mb-2" data-i18n="city1">City 1</label><select id="tz1" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-cyan-500 focus:outline-none bg-white"><option value="8">Beijing (UTC+8)</option><option value="9">Tokyo (UTC+9)</option><option value="5.5">Mumbai (UTC+5:30)</option><option value="0">London (UTC+0)</option><option value="-5" selected>New York (UTC-5)</option><option value="-8">Los Angeles (UTC-8)</option><option value="1">Berlin (UTC+1)</option><option value="10">Sydney (UTC+10)</option></select></div>
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="tz2" class="block text-sm font-semibold text-gray-700 mb-2" data-i18n="city2">City 2</label><select id="tz2" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-cyan-500 focus:outline-none bg-white"><option value="8">Beijing (UTC+8)</option><option value="9">Tokyo (UTC+9)</option><option value="5.5">Mumbai (UTC+5:30)</option><option value="0" selected>London (UTC+0)</option><option value="-5">New York (UTC-5)</option><option value="-8">Los Angeles (UTC-8)</option><option value="1">Berlin (UTC+1)</option><option value="10">Sydney (UTC+10)</option></select></div>
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200"><label for="tz3" class="block text-sm font-semibold text-gray-700 mb-2" data-i18n="city3">City 3 (optional)</label><select id="tz3" class="w-full px-3 py-2.5 text-sm rounded-lg border border-gray-300 focus:ring-2 focus:ring-cyan-500 focus:outline-none bg-white"><option value="" data-i18n="optNone">-- None --</option><option value="8" selected>Beijing (UTC+8)</option><option value="9">Tokyo (UTC+9)</option><option value="5.5">Mumbai (UTC+5:30)</option><option value="0">London (UTC+0)</option><option value="-5">New York (UTC-5)</option><option value="-8">Los Angeles (UTC-8)</option><option value="1">Berlin (UTC+1)</option><option value="10">Sydney (UTC+10)</option></select></div>
    </div>
    <button id="calcBtn" class="w-full bg-cyan-600 hover:bg-cyan-700 text-white font-semibold py-3 rounded-lg mb-6" data-i18n="findBtn">Find Best Times</button>
    <div id="results" class="hidden">
      <div class="bg-cyan-50 rounded-xl p-5 mb-6 border border-cyan-200"><p class="text-sm font-semibold text-cyan-800 mb-3" data-i18n="goldenTitle">Golden Hours (9AM-9PM local)</p><div id="overlapTimes" class="flex flex-wrap gap-2 mb-4"></div><p id="overlapInfo" class="text-sm text-cyan-700"></p></div>
      <div class="bg-gray-50 rounded-lg p-4 border border-gray-200 mb-6"><p class="text-sm font-semibold text-gray-700 mb-3" data-i18n="timelineTitle">24-Hour Timeline</p><div class="space-y-3" id="timelineContainer"></div><div class="flex justify-between mt-3 text-xs text-gray-400"><span>00:00</span><span>06:00</span><span>12:00</span><span>18:00</span><span>23:00</span></div></div>
    </div>
  </section>
  <section class="mt-10 mb-8"><h2 class="text-2xl font-bold text-gray-800 mb-4" data-i18n="tipsTitle">Cross-Timezone Tips</h2><div class="grid sm:grid-cols-2 gap-4"><div class="bg-cyan-50 rounded-lg p-4 border border-cyan-100"><h3 class="font-semibold text-cyan-800 mb-2" data-i18n="tip1t">Record Everything</h3><p class="text-sm text-cyan-700" data-i18n="tip1d">Always record for members in inconvenient zones.</p></div><div class="bg-teal-50 rounded-lg p-4 border border-teal-100"><h3 class="font-semibold text-teal-800 mb-2" data-i18n="tip2t">Rotate Times</h3><p class="text-sm text-teal-700" data-i18n="tip2d">Share the pain. Rotate meeting times.</p></div><div class="bg-green-50 rounded-lg p-4 border border-green-100"><h3 class="font-semibold text-green-800 mb-2" data-i18n="tip3t">Use Async</h3><p class="text-sm text-green-700" data-i18n="tip3d">Default to Slack, Notion, email when possible.</p></div><div class="bg-amber-50 rounded-lg p-4 border border-amber-100"><h3 class="font-semibold text-amber-800 mb-2" data-i18n="tip4t">Keep Short</h3><p class="text-sm text-amber-700" data-i18n="tip4d">15-min standups > 1-hour meetings.</p></div></div></section>
  <section id="faq" class="mb-8"><h2 class="text-2xl font-bold text-gray-800 mb-6" data-i18n="faq">FAQ</h2><div class="space-y-4"><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm" data-i18n="fq1">Find overlap hours?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p data-i18n="fa1">Select 2-3 cities. See when all are 9AM-9PM.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm" data-i18n="fq2">US-Europe best time?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p data-i18n="fa2">8-11 AM EST / 2-5 PM GMT.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm" data-i18n="fq3">US-Asia meetings?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p data-i18n="fa3">8-9 PM EST / 9-10 AM Beijing next day.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm" data-i18n="fq4">Handle DST?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p data-i18n="fa4">Tool shows UTC offsets. Check local DST rules.</p></div></details><details class="group bg-gray-50 rounded-lg border border-gray-200 open:bg-white open:shadow-sm"><summary class="cursor-pointer px-4 py-3 font-semibold text-sm" data-i18n="fq5">3-way overlap?</summary><div class="px-4 pb-4 text-sm text-gray-600"><p data-i18n="fa5">Difficult. One person often joins early/late.</p></div></details></div></section>
  <script type="application/ld+json" is:inline>{"@context":"https://schema.org","@type":"FAQPage","mainEntity":[{"@type":"Question","name":"Find overlap?","acceptedAnswer":{"@type":"Answer","text":"Select 2-3 cities. See 9AM-9PM overlap."}},{"@type":"Question","name":"US-Europe?","acceptedAnswer":{"@type":"Answer","text":"8-11 AM EST / 2-5 PM GMT."}},{"@type":"Question","name":"US-Asia?","acceptedAnswer":{"@type":"Answer","text":"8-9 PM EST / 9-10 AM Beijing."}},{"@type":"Question","name":"Handle DST?","acceptedAnswer":{"@type":"Answer","text":"Shows UTC offsets. Check local rules."}},{"@type":"Question","name":"3-way overlap?","acceptedAnswer":{"@type":"Answer","text":"Difficult. Rotate inconvenience."}}]}</script>
  <script is:inline define:vars={{}}>
    (function(){var N={"8":"Beijing","9":"Tokyo","5.5":"Mumbai","0":"London","-5":"New York","-8":"Los Angeles","1":"Berlin","10":"Sydney"};function calc(){var t1=parseFloat(document.getElementById("tz1").value),t2=parseFloat(document.getElementById("tz2").value),t3v=document.getElementById("tz3").value,t3=t3v?parseFloat(t3v):null;var zs=[t1,t2],ns=[N[t1.toString()]||"City1",N[t2.toString()]||"City2"];if(t3!==null){zs.push(t3);ns.push(N[t3.toString()]||"City3");}var ol=[];for(var u=0;u<24;u++){var ok=true;for(var z=0;z<zs.length;z++){var lh=(u+zs[z]+24)%24;if(lh<9||lh>21){ok=false;break;}}if(ok)ol.push(u);}var od=document.getElementById("overlapTimes");od.innerHTML="";if(ol.length===0){od.innerHTML='<p class="text-red-600 text-sm">'+(window._t?window._t("noOverlap"):"No golden overlap. Consider async.")+'</p>';}else{ol.forEach(function(u){var s=document.createElement("span");s.className="bg-green-100 text-green-800 text-xs font-semibold px-3 py-1.5 rounded-full border border-green-200";var p=[];zs.forEach(function(z,i){var lh=Math.floor((u+z+24)%24);p.push(ns[i]+" "+(lh<10?"0":"")+lh+":00");});s.textContent="UTC "+u+":00 | "+p.join(" | ");od.appendChild(s);});}document.getElementById("overlapInfo").textContent=(window._t?window._t("goldenCount"):"{n} golden hour(s) where all cities are 9AM-9PM.").replace("{n}",ol.length);var tl=document.getElementById("timelineContainer");tl.innerHTML="";zs.forEach(function(z,i){var row=document.createElement("div");row.className="flex items-center gap-3";var lab=document.createElement("div");lab.className="w-24 text-xs font-semibold text-gray-700 shrink-0";lab.textContent=ns[i]+" (UTC"+(z>=0?"+":"")+z+")";var bc=document.createElement("div");bc.className="flex-1 relative h-8 bg-gray-200 rounded overflow-hidden";for(var h=0;h<24;h++){var lH=(h+z+24)%24;var cell=document.createElement("div");cell.style.cssText="position:absolute;left:"+h/24*100+"%;width:"+100/24+"%;height:100%;";if(lH>=9&&lH<=21){var isO=true;zs.forEach(function(oz){var olh=(h+oz+24)%24;if(olh<9||olh>21)isO=false;});cell.className=isO?"tz-overlap":"tz-work";}else{cell.className="tz-sleep";}cell.title=(h<10?"0":"")+h+":00 UTC = "+(lH<10?"0":"")+lH+":00 "+ns[i];bc.appendChild(cell);}row.appendChild(lab);row.appendChild(bc);tl.appendChild(row);});document.getElementById("results").classList.remove("hidden");}document.getElementById("calcBtn").addEventListener("click",calc);window.calculate=calc;calc();})();
  </script>
